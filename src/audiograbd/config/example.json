{	
	"project_name": "devgrab",
	"date_time_format": "%Y%m%d-%H%M%S",

	"transcoding": {
		"enabled": false,

		"audio": {
			"codec": "opus",
			"bitrate_kbps": 24,
			"sample_rate": 16000
		},

		"skip_already_compressed": true
	},

	"speech-removal": {
		"enabled": true
	},

	"birdnet-prediction": {
		"enabled": false,
		"threshold": 0.1,
		"species_filter_file": null
	},

	"storage": {
		"provider": "",
		"sigma2": {
			"port": "12",
			"username": "ove"
		}
	},

	"scheduler": {
		"enabled":true,
		"interval_minutes": 1
	},

	"logger": {
		"level": "INFO",
		"format": "%(asctime)s %(name)s %(levelname)s %(message)s"
	}
}